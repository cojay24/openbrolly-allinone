rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ───────────────────────────────────────────────────────────────

    // Returns the clientId stored on the authenticated user's profile,
    // or null if the user document doesn't exist.
    function clientIdForUser(uid) {
      return exists(/databases/$(database)/documents/users/$(uid))
        ? get(/databases/$(database)/documents/users/$(uid)).data.clientId
        : null
    }

    // True when the signed-in user is the admin for the given clientId.
    // NOTE: the admin app uses the Firebase Admin SDK which bypasses all
    // security rules. These rules apply only to client-SDK access (e.g.
    // the public site's enquiry forms) and provide defense-in-depth.
    function isClientAdmin(clientId) {
      return request.auth != null
          && clientIdForUser(request.auth.uid) == clientId
    }

    // True when the signed-in user is any system admin (has a clientId field).
    // Used to allow admins to read and manage all user accounts.
    function isAdmin() {
      return request.auth != null
          && exists(/databases/$(database)/documents/users/$(request.auth.uid))
          && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('clientId', null) != null
    }

    // True when the signed-in user is an approved Location Owner.
    function isApprovedLocationOwner() {
      return request.auth != null
          && exists(/databases/$(database)/documents/users/$(request.auth.uid))
          && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.accountType == 'location-owner'
          && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.accountStatus == 'active'
    }

    // ── Users ─────────────────────────────────────────────────────────────────
    match /users/{uid} {
      // Admins can read any user profile (for the user management dashboard).
      // Users can read their own profile.
      allow read: if request.auth != null
                  && (request.auth.uid == uid || isAdmin())

      // Any authenticated user can create their own profile (signup flow).
      allow create: if request.auth != null && request.auth.uid == uid

      // Users can update their own profile with two exceptions handled below.
      // Admins can update any field on any user profile.
      allow update: if request.auth != null
                    && (
                      // Standard self-update: cannot touch accountType or accountStatus
                      (request.auth.uid == uid
                       && request.resource.data.accountType == resource.data.accountType
                       && request.resource.data.accountStatus == resource.data.accountStatus)

                      // Location-owner application: a viewer may set themselves to
                      // location-owner/pending. No other self-escalation is allowed.
                      || (request.auth.uid == uid
                          && resource.data.accountType == 'viewer'
                          && request.resource.data.accountType == 'location-owner'
                          && request.resource.data.accountStatus == 'pending')

                      || isAdmin()
                    )

      // ── Per-client lists ───────────────────────────────────────────────────
      // Lists are scoped per client so the same user has separate lists across
      // different client deployments. Only the owning user can read or write.
      match /clientLists/{clientId}/lists/{listId} {
        allow read, write: if request.auth != null && request.auth.uid == uid
      }
    }

    // ── Clients ───────────────────────────────────────────────────────────────
    match /clients/{clientId} {

      // Client document (name, brandConfig) is publicly readable so the
      // public site can load live brand colours without authentication.
      // Writes remain admin-only.
      allow read: if true
      allow write: if isClientAdmin(clientId)

      // ── Locations ───────────────────────────────────────────────────────────
      match /locations/{locationId} {

        // Published locations are publicly readable.
        // Drafts and admin-managed statuses are admin-only.
        // Location owners can read their own submissions.
        allow read: if resource.data.status == 'published'
                    || isClientAdmin(clientId)
                    || (request.auth != null && resource.data.submittedBy.uid == request.auth.uid)

        // Approved location owners may create a location in pending-approval state.
        // They must set submittedBy.uid to their own UID (prevents spoofing).
        allow create: if isClientAdmin(clientId)
                      || (isApprovedLocationOwner()
                          && request.resource.data.status == 'pending-approval'
                          && request.resource.data.submittedBy.uid == request.auth.uid)

        // Updates and deletes remain admin-only.
        allow update, delete: if isClientAdmin(clientId)

        // ── Enquiries ─────────────────────────────────────────────────────────
        match /enquiries/{enquiryId} {
          // Anyone can submit a contact or permit enquiry (public form, no auth).
          allow create: if true

          // Admins can read all enquiries.
          // Users can read their own enquiries (linked by userId).
          allow read: if isClientAdmin(clientId)
                      || (request.auth != null
                          && resource.data.userId == request.auth.uid)

          // Admins can update status freely.
          // Users can only clear the unreadByUser flag on their own enquiries.
          allow update: if isClientAdmin(clientId)
                        || (request.auth != null
                            && resource.data.userId == request.auth.uid
                            && request.resource.data.diff(resource.data).affectedKeys()
                               .hasOnly(['unreadByUser', 'unreadByAdmin']))

          // ── Messages subcollection ───────────────────────────────────────────
          match /messages/{messageId} {
            // Admins and the enquiry owner can read the thread.
            allow read: if isClientAdmin(clientId)
                        || (request.auth != null
                            && get(/databases/$(database)/documents/clients/$(clientId)/locations/$(locationId)/enquiries/$(enquiryId)).data.userId == request.auth.uid)

            // Admins can post as 'admin'. Enquiry owners can post as 'user'.
            allow create: if isClientAdmin(clientId)
                          || (request.auth != null
                              && get(/databases/$(database)/documents/clients/$(clientId)/locations/$(locationId)/enquiries/$(enquiryId)).data.userId == request.auth.uid
                              && request.resource.data.senderRole == 'user')
          }
        }
      }

      // ── Field schema ────────────────────────────────────────────────────────
      // Publicly readable so the public site can render custom fields on
      // location detail pages without requiring a sign-in.
      match /fieldSchema/{document=**} {
        allow read: if true
        allow write: if isClientAdmin(clientId)
      }
    }
  }
}
