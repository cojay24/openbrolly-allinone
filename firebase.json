{
  "hosting": [
    {
      "target": "public",
      "public": "apps/public/out",
      "cleanUrls": true,
      "trailingSlash": false,
      "rewrites": [
        { "source": "**", "destination": "/index.html" }
      ]
    },
    {
      "target": "admin",
      "public": "apps/admin/out",
      "cleanUrls": true,
      "trailingSlash": false,
      "rewrites": [
        { "source": "**", "destination": "/index.html" }
      ]
    }
  ],
  "firestore": {
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "storage": {
    "rules": "storage.rules"
  }
}
