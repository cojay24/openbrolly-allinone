rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // ── Brand logos ───────────────────────────────────────────────────────────
    // Public read; authenticated admin writes via Firebase client SDK.
    match /clients/{clientId}/brand/{file} {
      allow read: if true
      allow write: if request.auth != null
                   && request.resource.size < 2 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*')
    }

    // ── Location images ───────────────────────────────────────────────────────
    // Public read; authenticated admin writes via Firebase client SDK.
    match /clients/{clientId}/locations/{locationId}/{allImages=**} {
      allow read: if true
      allow write: if request.auth != null
                   && request.resource.size < 10 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*')
    }

    // ── Deny everything else ──────────────────────────────────────────────────
    match /{allPaths=**} {
      allow read, write: if false
    }
  }
}
