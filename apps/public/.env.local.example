# Copy to .env.local and fill in your values.

# Identifies which client tenant this deployment serves
NEXT_PUBLIC_CLIENT_ID=demo-client

# Firebase client SDK (browser) — safe to expose
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Firebase Admin SDK (server-side only — never exposed to browser)
# Used to read brandConfig and location data in Server Components.
# Option A: point to a service account JSON file
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
# Option B: individual fields from the service account JSON
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
FIREBASE_STORAGE_BUCKET=
