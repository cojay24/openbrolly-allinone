# ──────────────────────────────────────────────────────────────────────────────
# apps/admin — environment variables
# Copy to .env.local and fill in your values before running `pnpm dev` or deploying.
# ──────────────────────────────────────────────────────────────────────────────

# ── Firebase client SDK (browser-safe) ───────────────────────────────────────
# Used for Firebase Auth sign-in on the login page.
# Found in Firebase Console → Project settings → Your apps → Web app config.
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# ── Firebase Admin SDK (server-side only — never exposed to the browser) ──────
# Used by Server Components, Server Actions, and API routes.
#
# Option A — service account JSON file (recommended for local dev):
# GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/service-account.json
#
# Option B — individual fields from the service account JSON:
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
FIREBASE_STORAGE_BUCKET=your-project-id.firebasestorage.app

# ── Links ─────────────────────────────────────────────────────────────────────
# URL of the public-facing site (used for "View on site" links in the dashboard).
NEXT_PUBLIC_PUBLIC_SITE_URL=http://localhost:3000

# ── First-time setup ──────────────────────────────────────────────────────────
# After creating an admin user in Firebase Auth, create a user mapping document
# in Firestore so the dashboard knows which client this user manages:
#
#   Firebase Console → Firestore → users/{uid} → { clientId: "your-client-id" }
#
# Or run the seed script:   pnpm seed
